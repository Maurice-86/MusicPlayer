<Window
    x:Class="MusicPlayer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:convs="clr-namespace:MusicPlayer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MusicPlayer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:models="clr-namespace:MusicPlayer.Models"
    xmlns:views="clr-namespace:MusicPlayer.Views"
    xmlns:vm="clr-namespace:MusicPlayer.ViewModels"
    Title="MainWindow"
    Width="1050"
    Height="700"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    md:ThemeAssist.Theme="Light"
    Style="{StaticResource MaterialDesignWindow}"
    mc:Ignorable="d">

    <md:DialogHost DialogTheme="Inherit" Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <md:ColorZone
                Padding="16"
                md:ElevationAssist.Elevation="Dp0"
                DockPanel.Dock="Top"
                Mode="Standard">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <Button
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Command="{Binding MovePrevCommand}"
                            Content="{md:PackIcon Kind=ArrowLeft,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="后退" />

                        <Button
                            Margin="16,0,0,0"
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Command="{Binding MoveNextCommand}"
                            Content="{md:PackIcon Kind=ArrowRight,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="前进" />
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="Bold"
                        Text="WPF Music Player" />

                    <StackPanel
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Content="{md:PackIcon Kind=Theme,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="主题" />

                        <Button
                            Margin="16,0,0,0"
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Command="{Binding GoSettingsCommand}"
                            Content="{md:PackIcon Kind=Settings,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="设置" />
                        <Button
                            x:Name="MinimizeButton"
                            Margin="16,0,0,0"
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Content="{md:PackIcon Kind=Minimize,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="最小化" />
                        <Button
                            x:Name="ExitButton"
                            Margin="16,0,0,0"
                            md:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={StaticResource BrushRoundConverter}}"
                            Content="{md:PackIcon Kind=Close,
                                                  Size=20}"
                            Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                            Style="{StaticResource MaterialDesignToolButton}"
                            ToolTip="退出" />
                    </StackPanel>
                </Grid>
            </md:ColorZone>

            <md:DrawerHost
                Grid.Row="1"
                IsRightDrawerOpen="{Binding IsPlayListVisible}"
                RightDrawerCornerRadius="15">
                <md:DrawerHost.RightDrawerContent>
                    <DockPanel>
                        <Border
                            BorderBrush="#FF989898"
                            BorderThickness="0,0,0,1"
                            DockPanel.Dock="Top">
                            <DockPanel Margin="12,2">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Text="播放列表" />
                                <Button
                                    HorizontalAlignment="Right"
                                    BorderThickness="0"
                                    Command="{Binding DeleteAllCommand}"
                                    Content="清空"
                                    Foreground="#FF333333"
                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                            </DockPanel>
                        </Border>


                        <DataGrid
                            Grid.Row="1"
                            Width="450"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            HeadersVisibility="None"
                            IsReadOnly="True"
                            ItemsSource="{Binding PlayList.Songs}"
                            SelectedItem="{Binding SelectedItem}">
                            <DataGrid.InputBindings>
                                <!--  双击绑定  -->
                                <MouseBinding Command="{Binding RowDoubleClickCommand}" Gesture="LeftDoubleClick" />
                            </DataGrid.InputBindings>

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="1.5*"
                                    Binding="{Binding Title}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    Header="标题" />
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Artist}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    Header="作者" />
                                <DataGridTextColumn
                                    Width="0.5*"
                                    Binding="{Binding Origin}"
                                    EditingElementStyle="{StaticResource MaterialDesignDataGridTextColumnEditingStyle}"
                                    ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"
                                    Header="来源" />

                                <DataGridTemplateColumn Width="auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="16"
                                                Height="16"
                                                Padding="0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}"
                                                Content="{md:PackIcon Kind=Close}"
                                                Foreground="#FF333333"
                                                Style="{StaticResource MaterialDesignFlatButton}" />

                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <DataGrid.CellStyle>
                                <Style BasedOn="{StaticResource MaterialDesignDataGridCell}" TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </DockPanel>
                </md:DrawerHost.RightDrawerContent>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.3*" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <d:Border Background="LightBlue" />

                    <ListBox
                        x:Name="MenuBarListBox"
                        VerticalAlignment="Top"
                        ItemsSource="{Binding MenuItems}"
                        SelectedIndex="0"
                        Style="{StaticResource MaterialDesignNavigationPrimaryListBox}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding NavigateToViewCommand}" CommandParameter="{Binding ElementName=MenuBarListBox, Path=SelectedItem}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MenuItem}">
                                <StackPanel Margin="0,4" Orientation="Horizontal">
                                    <md:PackIcon
                                        Width="20"
                                        Height="20"
                                        Kind="{Binding Icon}" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:LocalMusicViewModel}">
                                <views:LocalMusicView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                                <views:SettingsView />
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Grid>
            </md:DrawerHost>

            <Grid Grid.Row="2">
                <ContentControl Content="{Binding PlayerViewModel}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:PlayerViewModel}">
                            <views:PlayerView />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>

        </Grid>
    </md:DialogHost>
</Window>
